#!/usr/bin/env sh
set -eu
sed -E '
    s/[^/]*[Ss]([0-9]{2})\.?[Ee]([0-9]{2})/\1.\2/;
    s/([0-9]{2}\.[0-9]{2}) - /\1 /;
    s/ *\([0-9]{3,4}p[^)/]*\)\.(mkv|mp4|avi|webm)$/.\1/;
    s/\.[0-9]{3,4}p\.[^/]*\.(mkv|mp4|avi|webm)$/.\1/;
    s/ [0-9]{3,4}p [^/]*\.(mkv|mp4|avi|webm)$/.\1/;
    /(^|[/])[0-9]{2}.[0-9]{2}\./{
        s/(\.)*\./\1 /g;
        s/(^|[/])([0-9]{2}) ([0-9]{2})/\1\2.\3/;
        s/ (mkv|kmp4|avi|webm)$/.\1/;
    }
'
